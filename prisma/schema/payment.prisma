model MomoPayment {
    requestId String @id 
    partnerCode String
    partnerName String?
    storeId String?
    amount Decimal
    orderId String
    orderInfo String
    autoCapture Boolean?
    redirectUrl String
    ipnUrl String
    requestType String
    extraData String
    lang String
    signature String

    userId String @db.Uuid
    paymentStatus PAYMENT_STATUS @default(PENDING)

    ticketId String @db.Uuid @unique
    ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user User @relation(fields: [userId], references: [id])
}