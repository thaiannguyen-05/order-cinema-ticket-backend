model Payment {
    requestId String @id 
    partnerCode String
    partnerName String?
    storeId String?
    amount Decimal
    orderId String
    orderInfo String
    autoCapture Boolean?
    redirectUrl String
    ipnUrl String
    requestType String
    extraData String
    lang String
    signature String

    userId String @db.Uuid

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user User @relation(fields: [userId], references: [id])
}