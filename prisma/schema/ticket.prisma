model Ticket {
  id        String   @id @default(uuid()) @db.Uuid
  code      String
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  filmOfCinemaId String @db.Uuid
  seatId String @db.Uuid @unique
  status TICKET_STATUS @default(AVAILABLE)

  order Order?

  seat Seat @relation(fields: [seatId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  filmOfCinema FilmOfCinema @relation(fields: [filmOfCinemaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}
