model Seat {
    id String @id @default(uuid()) @db.Uuid

    row Int
    column Int
    status SEAT_STATUS @default(AVAILABLE)

    filmId String @db.Uuid
    cinemaId Int @unique

    film FilmOfCinema @relation(fields: [filmId], references: [id], onDelete: Cascade, onUpdate: Cascade)
    cinema Cinema @relation(fields: [cinemaId], references: [cinema_id], onDelete: Cascade, onUpdate: Cascade)
}