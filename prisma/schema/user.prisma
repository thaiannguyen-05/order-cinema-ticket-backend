model User {
  id          String   @id @default(uuid()) @db.Uuid
  fullname    String
  email       String   @unique
  isActive    Boolean  @default(true)
  hashPassword String
  dateOfBirth DateTime
  address     String
  status      AccountStatus @default(PENDING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  sessions    Session[]
  tickets     Ticket[]
  @@index([email])
}
