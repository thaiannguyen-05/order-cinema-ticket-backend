model Schedule {
  id   String   @id
  date DateTime
  day  String

  filmId String @db.Uuid
  seatId Int

  film Film @relation(fields: [filmId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  seat Seat @relation(fields: [seatId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}
