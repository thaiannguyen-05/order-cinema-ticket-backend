model Film {
  film_id Int @id
  film_name String
  other_title Json?
  release_dates Json?
  age_rating Json?
  trailers Json?
  synopsis_long String?
  images Json?
  version_type VERSION_TYPE
  duration_mins Int
  review_stars Float
  review_txt String?
  distributor String?
  genres Json?
  cast Json?
  directors Json?
  producers Json?
  writers Json?

  filmOfCinema FilmOfCinema[]
}