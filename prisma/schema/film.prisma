model Film {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  author      String
  performer   String
  type        FilmType
  startedTime DateTime
  length      String
  lang        String
  rated       Float
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  filmOfTheaters FilmOfTheater[]
  schedules      Schedule[]
}
